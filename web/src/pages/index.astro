  <!-- nav scroll behavior + mobile menu -->
  <script>
    (function() {
      const nav = document.getElementById('nav-wrapper');
      const toggle = document.getElementById('nav-mobile-toggle');
      const menu = document.getElementById('nav-mobile-menu');
      const line1 = document.getElementById('nav-line-1');
      const line2 = document.getElementById('nav-line-2');
      if (!nav || !toggle || !menu) return;

      // scroll hide/show
      let lastY = 0;
      let hidden = false;
      const threshold = 60;

      window.addEventListener('scroll', () => {
        const y = window.scrollY;
        const delta = Math.abs(y - lastY);
        if (delta < threshold) return;

        const down = y > lastY;
        lastY = y;

        // always show at top
        if (y < 100) {
          if (hidden) {
            nav.style.transform = 'translateY(0)';
            hidden = false;
          }
          return;
        }

        if (down && !hidden) {
          nav.style.transform = 'translateY(-120%)';
          hidden = true;
        } else if (!down && hidden) {
          nav.style.transform = 'translateY(0)';
          hidden = false;
        }
      }, { passive: true });

      // mobile menu toggle
      let menuOpen = false;
      toggle.addEventListener('click', () => {
        menuOpen = !menuOpen;
        if (menuOpen) {
          menu.classList.remove('opacity-0', 'pointer-events-none');
          menu.classList.add('opacity-100', 'pointer-events-auto');
          line1.style.transform = 'rotate(45deg) translateY(3.25px)';
          line2.style.transform = 'rotate(-45deg) translateY(-3.25px)';
          document.body.style.overflow = 'hidden';
        } else {
          menu.classList.add('opacity-0', 'pointer-events-none');
          menu.classList.remove('opacity-100', 'pointer-events-auto');
          line1.style.transform = '';
          line2.style.transform = '';
          document.body.style.overflow = '';
        }
      });

      // close mobile menu on link click
      menu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          if (menuOpen) toggle.click();
        });
      });
    })();
  </script>
