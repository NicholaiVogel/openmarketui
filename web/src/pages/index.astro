---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="OpenMarketUI — Algorithmic Trading with Guardrails" description="Open source tools for building, backtesting, and deploying trading strategies on prediction markets. Kalshi, Polymarket, and more.">
  <div class="min-h-screen bg-white text-[#0a0a0a] selection:bg-[#0a0a0a] selection:text-white overflow-x-hidden">

    <!-- ═══════════════════════════════════════════ -->
    <!-- NAV — floating island                       -->
    <!-- ═══════════════════════════════════════════ -->
    <div id="nav-wrapper" class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-4 px-4 pointer-events-none transition-transform duration-400 ease-[cubic-bezier(0.16,1,0.3,1)]">
      <nav class="pointer-events-auto bg-white/85 backdrop-blur-xl border border-neutral-200/60 shadow-[0_2px_20px_rgba(0,0,0,0.12)] rounded-[12px] px-3 md:px-5 h-14 flex items-center gap-2 md:gap-6 max-w-fit">

        <!-- logo -->
        <a href="/" class="flex items-center gap-2.5 pl-2 shrink-0">
          <img src="/logo.png" alt="OpenMarketUI" class="w-7 h-7" />
          <span class="text-sm font-semibold tracking-[0.02em] hidden sm:inline">OpenMarketUI</span>
        </a>

        <!-- divider -->
        <div class="hidden md:block w-px h-6 bg-neutral-200/70"></div>

        <!-- links -->
        <div class="hidden md:flex items-center gap-1">
          <a href="#pipeline" class="text-[13px] text-neutral-500 hover:text-[#0a0a0a] transition-colors px-3 py-1.5 rounded-full hover:bg-neutral-100/60">Pipeline</a>
          <a href="#architecture" class="text-[13px] text-neutral-500 hover:text-[#0a0a0a] transition-colors px-3 py-1.5 rounded-full hover:bg-neutral-100/60">Architecture</a>
          <a href="#garden" class="text-[13px] text-neutral-500 hover:text-[#0a0a0a] transition-colors px-3 py-1.5 rounded-full hover:bg-neutral-100/60">Garden</a>
        </div>

        <!-- divider -->
        <div class="hidden md:block w-px h-6 bg-neutral-200/70"></div>

        <!-- actions -->
        <a href="https://github.com/SignetAI/openmarketui" class="flex items-center gap-1.5 bg-[#55a179] text-white text-[13px] font-medium px-4 py-2 rounded-[12px] hover:bg-[#478e68] transition-colors shrink-0">
          GitHub
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>

        <!-- mobile menu button -->
        <button id="nav-mobile-toggle" class="md:hidden flex flex-col gap-[5px] p-2 -mr-1" aria-label="Menu">
          <div class="w-5 h-[1.5px] bg-[#0a0a0a] transition-all origin-center" id="nav-line-1"></div>
          <div class="w-5 h-[1.5px] bg-[#0a0a0a] transition-all origin-center" id="nav-line-2"></div>
        </button>
      </nav>
    </div>

    <!-- mobile menu overlay -->
    <div id="nav-mobile-menu" class="fixed inset-0 z-40 bg-white/95 backdrop-blur-lg flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300">
      <a href="#pipeline" class="nav-mobile-link text-2xl font-display font-light text-neutral-500 hover:text-[#0a0a0a] transition-colors">Pipeline</a>
      <a href="#architecture" class="nav-mobile-link text-2xl font-display font-light text-neutral-500 hover:text-[#0a0a0a] transition-colors">Architecture</a>
      <a href="#garden" class="nav-mobile-link text-2xl font-display font-light text-neutral-500 hover:text-[#0a0a0a] transition-colors">Garden</a>
      <div class="h-px w-12 bg-neutral-200 my-2"></div>
      <a href="https://github.com/SignetAI/openmarketui" class="text-lg font-mono text-neutral-400 hover:text-[#0a0a0a] transition-colors">GitHub</a>
    </div>


    <!-- ═══════════════════════════════════════════ -->
    <!-- HERO                                        -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="relative pt-36 pb-20 md:pt-44 md:pb-32 lg:pt-52 lg:pb-40 px-6 md:px-12 lg:px-20 max-w-[1400px] mx-auto">

      <!-- halftone texture - right side, drifting -->
      <div class="absolute top-10 right-0 w-[500px] h-[700px] lg:w-[650px] lg:h-[900px] opacity-[0.08] halftone-md animate-dots-drift halftone-fade-r pointer-events-none" aria-hidden="true"></div>
      <!-- secondary halftone - bottom left, static -->
      <div class="absolute bottom-0 left-0 w-[300px] h-[300px] opacity-[0.04] halftone-sm pointer-events-none" style="-webkit-mask-image: radial-gradient(ellipse at bottom left, black 20%, transparent 70%); mask-image: radial-gradient(ellipse at bottom left, black 20%, transparent 70%);" aria-hidden="true"></div>

      <div class="relative z-10">
        <!-- micro-label -->
        <p class="animate-fade-up text-[10px] tracking-[0.3em] uppercase text-neutral-400 mb-6 font-mono">
          Open Source Trading Toolkit
        </p>

        <!-- headline -->
        <h1 class="animate-fade-up delay-100 font-display font-light text-5xl md:text-7xl lg:text-[5.5rem] xl:text-[6.5rem] leading-[1.05] tracking-[-0.03em] max-w-4xl mb-10">
          Test your strategy<br class="hidden md:inline" />
          with agents.
        </h1>

        <!-- subtext -->
        <p class="animate-fade-up delay-300 text-neutral-500 text-base md:text-lg leading-relaxed max-w-xl mb-16">
          Back-test heuristic and ML strategies with real market data and
          execute live trading— all from an interface designed for you and
          your agent.
        </p>

        <!-- platform tags + pipeline -->
        <div class="animate-fade-up delay-500 flex flex-col sm:flex-row gap-12 sm:gap-20">
          <div>
            <p class="text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-3 font-mono">Platforms</p>
            <div class="flex gap-3">
              <span class="text-xs font-mono font-bold px-3.5 py-1.5 bg-[#55a179] text-white rounded-[12px]">Kalshi</span>
              <span class="text-xs font-mono font-bold px-3.5 py-1.5 bg-[#363636] text-white rounded-[12px]">Polymarket</span>
            </div>
          </div>
          <div>
            <p class="text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-3 font-mono">Pipeline</p>
            <p class="text-xs font-mono text-neutral-500 flex items-center gap-2 flex-wrap">
              <span class="text-[#0a0a0a] font-medium">Source</span>
              <span class="text-[#68a574]">&rarr;</span>
              <span>Filter</span>
              <span class="text-[#68a574]">&rarr;</span>
              <span>Scorer</span>
              <span class="text-[#68a574]">&rarr;</span>
              <span>Selector</span>
              <span class="text-[#68a574]">&rarr;</span>
              <span class="text-[#0a0a0a] font-medium">Executor</span>
            </p>
          </div>
        </div>
      </div>

    </section>


    <!-- thin rule -->
    <div class="max-w-[1400px] mx-auto px-6 md:px-12 lg:px-20">
      <div class="h-px bg-neutral-100"></div>
    </div>


    <!-- ═══════════════════════════════════════════ -->
    <!-- PIPELINE + SCORER BEDS — unified section     -->
    <!-- ═══════════════════════════════════════════ -->
    <section id="pipeline" class="relative py-20 md:py-32 px-6 md:px-12 lg:px-20 max-w-[1400px] mx-auto">

      <div id="garden" class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">

        <!-- left: context -->
        <div class="lg:col-span-4 flex flex-col justify-center">
          <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-500 mb-4 font-mono">Live Pipeline</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight mb-6">
            Compose your edge.<br />Watch it think.
          </h2>
          <p class="text-sm text-neutral-500 leading-relaxed mb-10">
            Mix and weight scorers from different strategy families. Each candidate flows
            through your filters and scorers — the pipeline shows you exactly why a trade
            was taken or rejected.
          </p>

          <div class="space-y-5">
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-[#55a179] mt-1.5 shrink-0"></div>
              <p class="text-xs text-neutral-600 leading-relaxed">Trait-based pipeline — swap any stage without touching the rest</p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-[#55a179] opacity-60 mt-1.5 shrink-0"></div>
              <p class="text-xs text-neutral-600 leading-relaxed">Ensemble scorers combine signals with configurable weights</p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-1.5 h-1.5 rounded-full bg-[#55a179] opacity-30 mt-1.5 shrink-0"></div>
              <p class="text-xs text-neutral-600 leading-relaxed">Circuit breakers halt trading when drawdown limits are hit</p>
            </div>
          </div>

          <!-- weight distribution — compact -->
          <div class="mt-10 pt-8 border-t border-neutral-100">
            <p class="text-[10px] tracking-[0.25em] uppercase text-neutral-400 mb-4 font-mono">Scorer Weights</p>
            <div class="grid grid-cols-2 gap-x-6 gap-y-2 font-mono text-[11px]">
              <div class="flex justify-between">
                <span class="text-neutral-500">momentum</span>
                <span class="text-neutral-400">0.35</span>
              </div>
              <div class="flex justify-between">
                <span class="text-neutral-500">volume</span>
                <span class="text-neutral-400">0.20</span>
              </div>
              <div class="flex justify-between">
                <span class="text-neutral-500">mean_reversion</span>
                <span class="text-neutral-400">0.25</span>
              </div>
              <div class="flex justify-between">
                <span class="text-neutral-500">ensemble</span>
                <span class="text-neutral-400">0.20</span>
              </div>
            </div>
          </div>
        </div>

        <!-- right: terminal -->
        <div class="lg:col-span-8">
          <div class="relative bg-[#fafafa] border border-neutral-200 rounded-[12px] overflow-hidden">
            <!-- terminal chrome -->
            <div class="flex items-center gap-3 px-6 py-4 border-b border-neutral-100">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-neutral-200"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-neutral-200"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-neutral-200"></div>
              </div>
              <span class="text-[10px] font-mono tracking-wider text-neutral-400 ml-2">openmarketui / <span class="text-[#68a574]">paper-trading</span></span>
            </div>

            <!-- terminal content -->
            <div class="p-6 md:p-8 font-mono text-xs leading-[2.2] overflow-x-auto">
              <p class="text-neutral-400 mb-6">$ cargo run --release -p pm-kalshi -- paper --config config.toml</p>

              <div class="space-y-0.5">
                <p class="text-neutral-400">
                  <span class="inline-block w-20 text-neutral-300">init</span>
                  pipeline ready &middot; 8 scorers &middot; 4 groups &middot; $10,000 equity
                </p>
                <p class="text-neutral-400">
                  <span class="inline-block w-20 text-neutral-300">source</span>
                  KXBTC-26FEB25 &nbsp; 0.72 &rarr; 0.68 &nbsp; vol: 12,400
                </p>

                <div class="my-4 h-px bg-neutral-100"></div>

                <p class="text-neutral-400 terminal-line terminal-line-pass">
                  <span class="inline-block w-20 text-neutral-300">filter</span>
                  LiquidityFilter &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span class="text-neutral-500">pass</span> &nbsp; depth: $24.2k
                </p>
                <p class="text-neutral-400 terminal-line terminal-line-pass">
                  <span class="inline-block w-20 text-neutral-300">filter</span>
                  SpreadFilter &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span class="text-neutral-500">pass</span> &nbsp; spread: 0.02
                </p>
                <p class="text-neutral-400 terminal-line terminal-line-pass">
                  <span class="inline-block w-20 text-neutral-300">filter</span>
                  TimeToCloseFilter &nbsp;&nbsp;&nbsp; <span class="text-neutral-500">pass</span> &nbsp; 4h 22m remaining
                </p>

                <div class="my-4 h-px bg-neutral-100"></div>

                <p class="text-neutral-500 terminal-line terminal-line-score">
                  <span class="inline-block w-20 text-neutral-300">scorer</span>
                  MomentumScorer &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span class="text-[#0a0a0a] font-medium">0.81</span>
                </p>
                <p class="text-neutral-500 terminal-line terminal-line-score">
                  <span class="inline-block w-20 text-neutral-300">scorer</span>
                  BollingerMeanRev &nbsp;&nbsp;&nbsp; <span class="text-[#0a0a0a] font-medium">0.34</span>
                </p>
                <p class="text-neutral-500 terminal-line terminal-line-score">
                  <span class="inline-block w-20 text-neutral-300">scorer</span>
                  VolumeScorer &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <span class="text-[#0a0a0a] font-medium">0.67</span>
                </p>
                <p class="text-neutral-500 terminal-line terminal-line-score">
                  <span class="inline-block w-20 text-neutral-300">scorer</span>
                  OrderFlowScorer &nbsp;&nbsp;&nbsp;&nbsp; <span class="text-[#0a0a0a] font-medium">0.72</span>
                </p>

                <div class="my-4 h-px bg-neutral-100"></div>

                <p class="text-neutral-500 terminal-line terminal-line-signal">
                  <span class="inline-block w-20 text-neutral-300">ensemble</span>
                  WeightedScorer &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; composite: <span class="text-[#0a0a0a] font-semibold">0.71</span>
                </p>
                <p class="text-[#0a0a0a] font-medium terminal-line terminal-line-signal">
                  <span class="inline-block w-20 text-neutral-500">signal</span>
                  &rarr; LONG @ 0.68 &nbsp;&middot;&nbsp; size: $340 &nbsp;&middot;&nbsp; risk: 3.4%
                </p>
              </div>

              <!-- blinking cursor -->
              <div class="mt-6 flex items-center gap-1">
                <span class="text-neutral-300">$</span>
                <span class="w-2 h-4 bg-[#0a0a0a] inline-block" style="animation: blink 1.2s step-end infinite;"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- halftone backdrop for architecture -->
      <div class="absolute bottom-0 left-0 w-[500px] h-[700px] opacity-[0.06] halftone-lg halftone-fade pointer-events-none" aria-hidden="true"></div>

      <div class="relative z-10 mt-20 md:mt-28">

        <!-- architecture intro -->
        <div id="architecture" class="max-w-xl mb-12">
          <p class="text-[10px] tracking-[0.3em] uppercase text-neutral-500 mb-4 font-mono">Architecture</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight mb-6">
            Designed like a garden.
          </h2>
          <p class="text-sm text-neutral-500 leading-relaxed">
            Strategies are specimens. Scorers grow in beds. Trades are harvests.
            The whole system is built on composable traits — swap any piece
            without uprooting the rest.
          </p>
        </div>

        <!-- architecture grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-neutral-100 border border-neutral-100 rounded-[12px] overflow-hidden">

          <!-- pm-core -->
          <div class="bg-white p-8 md:p-10 hover-lift">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-4">pm-core</p>
            <h3 class="text-sm font-semibold mb-2">Foundation</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">
              MarketCandidate, TradingContext, and all pipeline traits.
              The types everything else builds on.
            </p>
          </div>

          <!-- pm-garden -->
          <div class="bg-white p-8 md:p-10 hover-lift">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-4">pm-garden</p>
            <h3 class="text-sm font-semibold mb-2">The Garden</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Scorers and filters organized into beds by strategy family —
              momentum, mean reversion, volume, ensemble.
            </p>
          </div>

          <!-- pm-engine -->
          <div class="bg-white p-8 md:p-10 hover-lift">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-4">pm-engine</p>
            <h3 class="text-sm font-semibold mb-2">Engine</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Risk management, position sizing, circuit breakers,
              and the backtesting harness.
            </p>
          </div>

          <!-- pm-store -->
          <div class="bg-white p-8 md:p-10 hover-lift">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-4">pm-store</p>
            <h3 class="text-sm font-semibold mb-2">Root Cellar</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">
              SQLite persistence layer. Market data, trade history,
              backtest results — all local, all yours.
            </p>
          </div>

          <!-- pm-server -->
          <div class="bg-white p-8 md:p-10 hover-lift">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-4">pm-server</p>
            <h3 class="text-sm font-semibold mb-2">Greenhouse</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">
              REST + WebSocket server. Real-time state streaming
              to watchtower and web dashboards.
            </p>
          </div>

          <!-- pm-kalshi -->
          <div class="bg-white p-8 md:p-10 hover-lift">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-4">pm-kalshi</p>
            <h3 class="text-sm font-semibold mb-2">Kalshi Engine</h3>
            <p class="text-xs text-neutral-500 leading-relaxed">
              Full Kalshi integration — API client, paper trading,
              backtesting, and live execution.
            </p>
          </div>

        </div>

      </div>
    </section>


    <!-- thin rule -->
    <div class="max-w-[1400px] mx-auto px-6 md:px-12 lg:px-20">
      <div class="h-px bg-neutral-100"></div>
    </div>


    <!-- ═══════════════════════════════════════════ -->
    <!-- WATCHTOWER + TOOLS                          -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="relative py-20 md:py-28 px-6 md:px-12 lg:px-20 max-w-[1400px] mx-auto">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- watchtower card — full TUI mockup -->
        <div class="lg:col-span-2 border border-neutral-200 rounded-[12px] relative overflow-hidden hover-lift">
          <div class="absolute top-0 right-0 w-80 h-80 opacity-[0.06] halftone-sm pointer-events-none" aria-hidden="true"></div>

          <div class="p-8 md:p-10 pb-6">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-neutral-500 mb-6">Interface</p>
            <h3 class="font-display text-2xl md:text-3xl leading-tight mb-4">Watchtower</h3>
            <p class="text-sm text-neutral-500 leading-relaxed max-w-xl">
              Terminal UI built with OpenTUI. Monitor positions, engine state,
              scorer weights, and trade history — all from your terminal.
              Ships with 35+ themes.
            </p>
          </div>

          <!-- TUI mockup — monochrome -->
          <div class="mx-4 md:mx-6 mb-4 md:mb-6 rounded-[12px] overflow-hidden border border-neutral-200 bg-[#fafafa] font-mono text-[11px] leading-[1.7]">

            <!-- TUI header -->
            <div class="flex justify-between px-4 py-1.5 bg-neutral-100">
              <span>
                <span class="text-[#0a0a0a]">OpenMarketUI</span>
                <span class="text-neutral-300"> / </span>
                <span class="text-[#205ea6]">watchtower</span>
              </span>
              <span>
                <span class="text-[#66800b] font-medium">PAPER</span>
                <span class="text-[#66800b]"> +$124.80 (+1.25%)</span>
                <span class="text-neutral-400"> │ Ctrl+P</span>
              </span>
            </div>

            <!-- portfolio stats -->
            <div class="flex gap-6 px-4 py-1 bg-neutral-100">
              <span><span class="text-neutral-400">cash </span><span class="text-[#0a0a0a]">$1,937.20</span></span>
              <span><span class="text-neutral-400">invested </span><span class="text-[#0a0a0a]">$8,062.80</span></span>
              <span><span class="text-neutral-400">equity </span><span class="text-[#66800b]">$10,124.80</span></span>
              <span><span class="text-neutral-400">return </span><span class="text-[#66800b]">+1.25%</span></span>
              <span><span class="text-neutral-400">P&L </span><span class="text-[#66800b]">+$124.80</span></span>
            </div>

            <!-- tab bar -->
            <div class="flex justify-center gap-0 px-4 py-1.5 border-b border-neutral-200">
              <span><span class="text-[#205ea6] font-medium">1</span><span class="text-[#0a0a0a]"> overview</span></span>
              <span class="text-neutral-200"> &nbsp;│&nbsp; </span>
              <span><span class="text-neutral-400">2</span><span class="text-neutral-400"> positions</span></span>
              <span class="text-neutral-200"> &nbsp;│&nbsp; </span>
              <span><span class="text-neutral-400">3</span><span class="text-neutral-400"> trades</span></span>
              <span class="text-neutral-200"> &nbsp;│&nbsp; </span>
              <span><span class="text-neutral-400">4</span><span class="text-neutral-400"> engine</span></span>
              <span class="text-neutral-200"> &nbsp;│&nbsp; </span>
              <span><span class="text-neutral-400">5</span><span class="text-neutral-400"> decisions</span></span>
              <span class="text-neutral-200"> &nbsp;│&nbsp; </span>
              <span><span class="text-neutral-400">6</span><span class="text-neutral-400"> timeline</span></span>
              <span class="text-neutral-200"> &nbsp;│&nbsp; </span>
              <span><span class="text-neutral-400">7</span><span class="text-neutral-400"> data</span></span>
            </div>

            <!-- stats row -->
            <div class="flex gap-4 px-4 py-1.5">
              <span><span class="text-neutral-400">scorers </span><span class="text-[#0a0a0a]">8</span></span>
              <span><span class="text-[#66800b]">●</span><span class="text-neutral-400"> active </span><span class="text-[#0a0a0a]">8</span></span>
              <span><span class="text-neutral-400">groups </span><span class="text-[#0a0a0a]">4</span></span>
              <span><span class="text-neutral-400">total weight </span><span class="text-[#0a0a0a]">1.00</span></span>
              <span><span class="text-neutral-400">equity </span><span class="text-[#66800b]">$10,124.80</span></span>
            </div>

            <!-- strategies panel -->
            <div class="mx-3 mt-1 mb-2 border border-neutral-200 rounded">
              <div class="px-3 py-0.5 text-[10px] text-neutral-400 border-b border-neutral-200">strategies</div>
              <!-- table header -->
              <div class="grid px-3 py-1 text-neutral-400" style="grid-template-columns: 20px 1fr 1fr 80px 60px 100px;">
                <span></span><span>name</span><span>group</span><span>status</span><span>weight</span><span>distribution</span>
              </div>
              <!-- rows -->
              {[
                { name: 'MomentumScorer', group: 'momentum', weight: 0.15, bar: 3 },
                { name: 'TimeDecayScorer', group: 'momentum', weight: 0.10, bar: 2 },
                { name: 'MTFMomentum', group: 'momentum', weight: 0.10, bar: 2 },
